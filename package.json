{
  "name": "anchronos",
  "displayName": "Anchronos",
  "publisher": "jonathanmenichetti",
  "description": "Freeze your cursors in time, roam freely, and release them all at once.",
  "version": "0.0.1",
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/jonathanmenichetti/anchronos"
  },
  "contributes": {
    "commands": [
      {
        "command": "anchronos.toggleTimeFlow",
        "title": "Alternate Time Flow (Freeze/Unfreeze Cursors)",
        "category": "Anchronos"
      },
      {
        "command": "anchronos.plantParadox",
        "title": "Plant Paradox (Add/Remove Anchor)",
        "category": "Anchronos"
      },
      {
        "command": "anchronos.clearCurrentAnchors",
        "title": "Clear Anchors in Current File",
        "category": "Anchronos"
      },
      {
        "command": "anchronos.clearAllAnchors",
        "title": "Clear All Anchors (Nuclear Reset)",
        "category": "Anchronos"
      }
    ],
    "keybindings": [
      {
        "command": "anchronos.toggleTimeFlow",
        "key": "alt+l",
        "mac": "alt+l",
        "when": "editorTextFocus"
      },
      {
        "command": "anchronos.plantParadox",
        "key": "alt+a",
        "mac": "alt+a",
        "when": "editorTextFocus && inTimeStasis"
      }
    ],
    "configuration": {
      "title": "Anchronos",
      "properties": {
        "anchronos.showNotifications": {
          "type": "boolean",
          "default": true,
          "description": "Show status notifications when freezing/unfreezing time. Disable if you find them distracting during heavy use."
        },
        "anchronos.anchorColor": {
          "type": "string",
          "default": "",
          "markdownDescription": "Custom hex color for frozen anchor decorations (e.g. `#FF6B6B`). Leave empty to use the current theme's cursor color."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.120.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "esbuild": "^0.27.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
